# ─────────────────────────────────────────────────────────────
# MemoraX — Environment Variables (example)
# Copy this file to `.env` and fill in real values.
# NEVER commit your real `.env` — it is gitignored.
# ─────────────────────────────────────────────────────────────

# ── Database ──
# SQLite for local dev; use Postgres (Neon/Supabase) for production
DATABASE_URL="file:./dev.db"

# ── NextAuth.js ──
# Generate a strong secret:  openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"
# Public URL of the deployed app
NEXTAUTH_URL="http://localhost:3000"

# ── Stripe (international cards) ──
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
# Get from https://dashboard.stripe.com/webhooks  (endpoint: /api/stripe/webhook)
STRIPE_WEBHOOK_SECRET=""
# Optional: publishable key if using Stripe.js on the client
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ── Bolivian bank QR (QR Interbancario) ──
# Your merchant bank account details for QR payments
QR_MERCHANT_BANK="Banco de Unión"
QR_MERCHANT_NAME="MemoraX Bolivia S.R.L."
QR_MERCHANT_ACCOUNT="1000200030004000"
QR_MERCHANT_CI="1234567 LP"

# ── Tigo Money ──
# Your Tigo Money merchant wallet
TIGO_MERCHANT_PHONE="70700000"
TIGO_MERCHANT_NAME="MEMORAX BO"

# ── AI / z-ai-web-dev-sdk ──
# (configured by the sandbox environment — no key needed in .env for dev)

# ── Next.js ──
NODE_ENV="development"
