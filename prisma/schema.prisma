// MemoraX — Prisma schema
// memorae-inspired AI assistant for students, teachers, and parents

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------- Users & Roles ----------

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   @default("STUDENT") // STUDENT | PARENT | TEACHER
  avatar    String?  // emoji or initials
  grade     String?  // for students e.g. "7th Grade"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  studentEnrollments Enrollment[]     @relation("StudentEnrollments")
  studentMemories    Memory[]         @relation("StudentMemories")
  studentChats       ChatMessage[]    @relation("StudentChats")
  studentSubmissions Submission[]     @relation("StudentSubmissions")
  studentReminders   Reminder[]       @relation("StudentReminders")
  studentTutorMsgs   TeacherMessage[] @relation("TeacherMessageStudent")

  // gamification
  studentProfile     StudentProfile?
  studentCosmetics   StudentCosmetic[]
  achievements       Achievement[]
  reviewCards        ReviewCard[]
  examPlans          ExamPlan[]
  studyGroupMemberships StudyGroupMember[]
  studyGroupsOwned   StudyGroup[]      @relation("StudyGroupOwner")

  teacherCourses     Course[]         @relation("TeacherCourses")
  teacherMessages    TeacherMessage[] @relation("TeacherMessageTeacher")

  // parent ↔ teacher messaging
  parentMessagesSent   ParentTeacherMessage[] @relation("ParentTeacherMessageParent")
  teacherMessagesRecv  ParentTeacherMessage[] @relation("ParentTeacherMessageTeacher2")

  familyMemberships  FamilyMember[]   @relation("FamilyMemberUser")
}

// ---------- Family Bundles (up to 2 parents + N students) ----------

model Family {
  id        String         @id @default(cuid())
  name      String         // e.g. "The Garcia Family"
  createdAt DateTime       @default(now())
  members   FamilyMember[]
}

model FamilyMember {
  id        String   @id @default(cuid())
  familyId  String
  userId    String
  role      String   // STUDENT | PARENT (within the family)
  createdAt DateTime @default(now())

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user   User   @relation("FamilyMemberUser", fields: [userId], references: [id], onDelete: Cascade)
}

// ---------- Mock Google Classroom ----------

model Course {
  id          String        @id @default(cuid())
  name        String        // e.g. "Algebra II"
  subject     String?       // e.g. "Math"
  teacherId   String
  color       String        @default("emerald") // tailwind color token
  room        String?
  createdAt   DateTime      @default(now())

  teacher      User          @relation("TeacherCourses", fields: [teacherId], references: [id], onDelete: Cascade)
  enrollments  Enrollment[]
  assignments  Assignment[]
  teacherMessages TeacherMessage[]
}

model Enrollment {
  id        String   @id @default(cuid())
  courseId  String
  studentId String
  createdAt DateTime @default(now())

  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student User   @relation("StudentEnrollments", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
}

model Assignment {
  id          String       @id @default(cuid())
  courseId    String
  title       String
  description String?
  dueDate     DateTime
  maxPoints   Int          @default(100)
  type        String       @default("HOMEWORK") // HOMEWORK | QUIZ | PROJECT | ESSAY | READING
  createdAt   DateTime     @default(now())

  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  submissions Submission[]
}

model Submission {
  id           String   @id @default(cuid())
  assignmentId String
  studentId    String
  status       String   @default("NOT_STARTED") // NOT_STARTED | IN_PROGRESS | SUBMITTED | GRADED
  score        Int?
  submittedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User       @relation("StudentSubmissions", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
}

// ---------- Memory Layer (the memorae DNA) ----------

model Memory {
  id            String   @id @default(cuid())
  studentId     String
  type          String   // NOTE | CONCEPT | HOMEWORK | TUTOR_SESSION | WEAK_AREA | STUDY_TIP
  content       String
  tags          String?  // comma-separated
  relatedAssignmentId String?
  importance    Int      @default(3) // 1-5
  createdAt     DateTime @default(now())

  student User @relation("StudentMemories", fields: [studentId], references: [id], onDelete: Cascade)
}

// ---------- AI Tutor Chat ----------

model ChatMessage {
  id         String   @id @default(cuid())
  studentId  String
  role       String   // user | assistant
  content    String
  imageUrl   String?  // stored homework image (data URL or path)
  mode       String?  // socratic | solution (for assistant msgs)
  createdAt  DateTime @default(now())

  student User @relation("StudentChats", fields: [studentId], references: [id], onDelete: Cascade)
}

// ---------- Parent Reminders (WhatsApp-style inbox) ----------

model Reminder {
  id           String    @id @default(cuid())
  studentId    String
  familyId     String
  type         String    // DAILY_DIGEST | DUE_TODAY | OVERDUE | DUE_SOON | PROGRESS_UPDATE | FRUSTRATION_SIGNAL | CELEBRATION | SIBLING_MILESTONE
  title        String
  body         String
  scheduledFor DateTime
  sentAt       DateTime?
  readAt       DateTime?
  createdAt    DateTime  @default(now())

  student User @relation("StudentReminders", fields: [studentId], references: [id], onDelete: Cascade)
}

// ---------- Teacher → Student messaging ----------

model TeacherMessage {
  id        String   @id @default(cuid())
  courseId  String
  teacherId String
  studentId String
  content   String
  readAt    DateTime?
  createdAt DateTime @default(now())

  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher User   @relation("TeacherMessageTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  student User   @relation("TeacherMessageStudent", fields: [studentId], references: [id], onDelete: Cascade)
}

// ---------- Gamification: profile, cosmetics, achievements ----------

model StudentProfile {
  studentId      String    @id
  xp             Int       @default(0)
  coins          Int       @default(50) // starting bonus
  streakDays     Int       @default(0)
  lastActiveDate DateTime?
  // counters
  totalChats     Int       @default(0)
  totalHomework  Int       @default(0)
  totalReviews   Int       @default(0)
  // avatar equipment (cosmetic ids from catalog)
  scene          String    @default("bedroom")
  character      String    @default("student")
  pet            String    @default("none")
  accessory      String    @default("none")
  // parent-set screen-time schedule (JSON: {studyStart:"16:00", studyEnd:"20:00", downtimeStart:"21:00", downtimeEnd:"07:00", enabled:true})
  studyHours     String?
  // parent-set focus areas / goals (comma-separated, e.g. "fractions,essay writing")
  focusAreas     String?
  updatedAt      DateTime  @updatedAt

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model StudentCosmetic {
  id         String   @id @default(cuid())
  studentId  String
  cosmeticId String   // references the in-code catalog
  unlockedAt DateTime @default(now())

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, cosmeticId])
}

model Achievement {
  id         String   @id @default(cuid())
  studentId  String
  key        String   // e.g. "first_chat", "streak_7", "level_5"
  unlockedAt DateTime @default(now())

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, key])
}

// ---------- Spaced repetition ----------

model ReviewCard {
  id          String   @id @default(cuid())
  studentId   String
  memoryId    String?
  front       String   // prompt / question
  back        String   // answer / explanation
  // SM-2 lite scheduling fields
  ease        Float    @default(2.5)
  interval    Int      @default(1) // days
  dueDate     DateTime @default(now())
  repetitions Int      @default(0)
  createdAt   DateTime @default(now())

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

// ---------- Exam prep ----------

model ExamPlan {
  id            String   @id @default(cuid())
  studentId     String
  title         String
  examDate      DateTime
  generatedPlan String   // JSON string: [{day, date, tasks:[...]}]
  createdAt     DateTime @default(now())

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

// ---------- Study groups ----------

model StudyGroup {
  id          String   @id @default(cuid())
  name        String
  subject     String?
  createdById String
  createdAt   DateTime @default(now())

  createdBy User                @relation("StudyGroupOwner", fields: [createdById], references: [id], onDelete: Cascade)
  members   StudyGroupMember[]
}

model StudyGroupMember {
  id        String   @id @default(cuid())
  groupId   String
  studentId String
  joinedAt  DateTime @default(now())

  group   StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student User       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([groupId, studentId])
}

// ---------- Parent ↔ Teacher messaging ----------

model ParentTeacherMessage {
  id        String   @id @default(cuid())
  parentId  String
  teacherId String
  studentId String?  // optional: about a specific student
  courseId  String?  // optional: about a specific course
  direction String   // PARENT_TO_TEACHER | TEACHER_TO_PARENT
  content   String
  readAt    DateTime?
  createdAt DateTime @default(now())

  parent  User @relation("ParentTeacherMessageParent", fields: [parentId], references: [id], onDelete: Cascade)
  teacher User @relation("ParentTeacherMessageTeacher2", fields: [teacherId], references: [id], onDelete: Cascade)
}


